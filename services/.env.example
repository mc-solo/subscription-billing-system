# server config
CUSTOMER_SERVER_HOST=0.0.0.0
CUSTOMER_SERVER_PORT=8080
CUSTOMER_GRPC_PORT=50051

# database config
CUSTOMER_DB_HOST=localhost
CUSTOMER_DB_PORT=3306
CUSTOMER_DB_USER=root
CUSTOMER_DB_PASSWORD=
CUSTOMER_DB_NAME=subscription-billing-sys

# auth
CUSTOMER_AUTH_JWT_SECRET=value-to-be-changed-in-prod
CUSTOMER_AUTH_JWT_EXPIRY_HOURS=24
CUSTOMER_AUTH_BCRYPT_COST=12
CUSTOMER_AUTH_MIN_PASSWORD_LENGTH=8
CUSTOMER_AUTH_LOCKOUT_THRESHOLD=5
CUSTOMER_AUTH_LOCKOUT_DURATION_MINUTES=15
CUSTOMER_AUTH_VERIFICATION_TOKEN_EXPIRY_HOURS=24
CUSTOMER_AUTH_RESET_TOKEN_EXPIRY_MINUTES=60
# logging 
LOG-LEVEL=info